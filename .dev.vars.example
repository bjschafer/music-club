# Copy to `.dev.vars` (gitignored) and fill in from the Discord Developer Portal.
# Used by both `wrangler dev` and `npm run register`.

DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# Optional: set during development to register commands to a single test server
# instantly (global registration can take up to ~1 hour to propagate).
DISCORD_DEV_GUILD_ID=
